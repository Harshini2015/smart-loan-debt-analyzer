# Backend environment variables (copy to backend/.env)

MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Groq API — https://console.groq.com/keys (key must start with gsk_)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Feature flags
ENABLE_FRAUD_DETECTION=true
ENABLE_EMERGENCY_FUND=true
ENABLE_FAMILY_ECOSYSTEM=true
ENABLE_VOICE_TRACKING=false
ENABLE_GOAL_TIMELINE=true
