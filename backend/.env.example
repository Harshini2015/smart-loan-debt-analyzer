# Copy to .env and fill in values

# MongoDB Atlas — Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Atlas → Connect → Compass → "Standard connection string" (if SRV fails on Windows)
MONGO_URI_STANDARD=mongodb://<user>:<pass>@<host1>:27017,<host2>:27017,<host3>:27017/<dbname>?ssl=true&authSource=admin&retryWrites=true&w=majority
# Uses 8.8.8.8 / 1.1.1.1 for SRV lookups; set to "system" to use PC DNS only
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

PORT=5000
NODE_ENV=production
JWT_SECRET=change_me_to_a_long_random_secret

# Groq API — https://console.groq.com/keys (key must start with gsk_)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
